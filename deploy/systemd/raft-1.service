[Unit]
Description=Raft Node 1 Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/paxos_raft_consensus_protocol
ExecStart=/usr/bin/node dist/main.js
Environment=APP_MODE=raft
Environment=PORT=3001
Environment=PEERS=http://127.0.0.1:3002,http://127.0.0.1:3003
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
