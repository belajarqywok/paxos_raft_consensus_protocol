[Unit]
Description=Paxos Node 1 Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/paxos_raft_consensus_protocol
ExecStart=/usr/bin/node dist/main.js
Environment=APP_MODE=paxos
Environment=PORT=4001
Environment=PEERS=http://127.0.0.1:4002,http://127.0.0.1:4003
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
