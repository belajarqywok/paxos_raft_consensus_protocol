# ============================================================
# .env.example — Template konfigurasi untuk APP_MODE=lib
# ============================================================
# Copy file ini jadi .env lalu isi nilainya:
#   cp .env.example .env
# ============================================================

APP_MODE=lib
PORT=5000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=libraries
DB_POOL_SIZE=10

JWT_SECRET=ganti_dengan_secret_yang_panjang_dan_aman_di_production
JWT_EXPIRES_IN=60m
